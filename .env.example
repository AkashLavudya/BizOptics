# Environment Variables - Business Opportunity Intelligence Platform

# ============================================================
# DATABASE
# ============================================================
DATABASE_URL="postgresql://username:password@localhost:5432/boi_platform?schema=public"

# ============================================================
# JWT AUTHENTICATION
# ============================================================
JWT_SECRET="your-super-secret-jwt-key-minimum-32-characters-long"
JWT_REFRESH_SECRET="your-super-secret-refresh-jwt-key-minimum-32-characters-long"
JWT_EXPIRES_IN="8h"
JWT_REFRESH_EXPIRES_IN="30d"

# ============================================================
# SERVER CONFIG
# ============================================================
NODE_ENV="development"
PORT=3001
API_PREFIX="api/v1"
CORS_ORIGINS="http://localhost:3000"

# ============================================================
# FRONTEND CONFIG
# ============================================================
NEXT_PUBLIC_API_URL="http://localhost:3001/api/v1"
NEXT_PUBLIC_APP_NAME="BizOptics"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ============================================================
# GOOGLE PLACES API
# ============================================================
GOOGLE_PLACES_API_KEY="your-google-places-api-key"
GOOGLE_MAPS_API_KEY="your-google-maps-api-key"

# ============================================================
# EMAIL (SMTP)
# ============================================================
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
SMTP_FROM="BizOptics <noreply@bizoptics.com>"

# ============================================================
# REDIS (Optional - for caching and queues)
# ============================================================
REDIS_URL="redis://localhost:6379"

# ============================================================
# RATE LIMITING
# ============================================================
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# ============================================================
# BCRYPT
# ============================================================
BCRYPT_ROUNDS=12

# ============================================================
# ADMIN CREDENTIALS (Initial Seed)
# ============================================================
ADMIN_EMAIL="admin@bizoptics.com"
ADMIN_PASSWORD="Admin@123456"
ADMIN_FIRST_NAME="Admin"
ADMIN_LAST_NAME="User"

# ============================================================
# DEPLOYMENT
# ============================================================
# Vercel (Frontend)
VERCEL_TOKEN="your-vercel-token"

# Railway/Render (Backend)
RAILWAY_TOKEN="your-railway-token"

# ============================================================
# LOGGING
# ============================================================
LOG_LEVEL="debug"

# ============================================================
# WEBSITE ANALYSIS
# ============================================================
ANALYSIS_TIMEOUT_MS=10000
ANALYSIS_USER_AGENT="Mozilla/5.0 BizOptics-Bot/1.0"
