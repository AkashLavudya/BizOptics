# =============================================================
#  BizOptics — Environment Variables Reference
#  Copy this file to:
#    → apps/server/.env        (backend)
#    → apps/web/.env.local     (frontend)
# =============================================================

# -------------------------------------------------------------
# DATABASE (PostgreSQL)
# -------------------------------------------------------------
# Local development:
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/bizoptics?schema=public"
# Production (Neon):
# DATABASE_URL="postgresql://neondb_owner:xxxx@ep-xxx.ap-southeast-1.aws.neon.tech/neondb?sslmode=require"

# -------------------------------------------------------------
# JWT AUTHENTICATION
# Generate secrets: openssl rand -hex 32
# -------------------------------------------------------------
JWT_SECRET="your-super-secret-jwt-key-minimum-32-characters-long"
JWT_REFRESH_SECRET="your-super-secret-refresh-jwt-key-minimum-32-chars"
JWT_EXPIRES_IN="8h"
JWT_REFRESH_EXPIRES_IN="30d"

# -------------------------------------------------------------
# SERVER CONFIG (Backend — apps/server/.env)
# -------------------------------------------------------------
NODE_ENV="development"
PORT=3001
API_PREFIX="api/v1"
# Comma-separated list of allowed frontend origins
CORS_ORIGINS="http://localhost:3000"
# Production example:
# CORS_ORIGINS="https://your-app.vercel.app"

# -------------------------------------------------------------
# FRONTEND CONFIG (Frontend — apps/web/.env.local)
# -------------------------------------------------------------
NEXT_PUBLIC_API_URL="http://localhost:3001/api/v1"
# Production example:
# NEXT_PUBLIC_API_URL="https://bizoptics-backend-api.onrender.com/api/v1"
NEXT_PUBLIC_APP_NAME="BizOptics"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# -------------------------------------------------------------
# GOOGLE PLACES API (Optional)
# Leave blank to use built-in mock data for all US & India locations
# Get key: https://console.cloud.google.com → Places API
# -------------------------------------------------------------
GOOGLE_PLACES_API_KEY=""
GOOGLE_MAPS_API_KEY=""

# -------------------------------------------------------------
# EMAIL / SMTP (Nodemailer)
# For Gmail: enable 2FA and create an App Password
# https://myaccount.google.com/apppasswords
# -------------------------------------------------------------
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-16-char-app-password"
SMTP_FROM="BizOptics <noreply@bizoptics.com>"

# -------------------------------------------------------------
# RATE LIMITING
# -------------------------------------------------------------
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# -------------------------------------------------------------
# BCRYPT (password hashing rounds — higher = slower but safer)
# -------------------------------------------------------------
BCRYPT_ROUNDS=12

# -------------------------------------------------------------
# ADMIN SEED CREDENTIALS (used only during: npm run prisma:seed)
# -------------------------------------------------------------
ADMIN_EMAIL="admin@bizoptics.com"
ADMIN_PASSWORD="Admin@123456"
ADMIN_FIRST_NAME="Admin"
ADMIN_LAST_NAME="User"

# -------------------------------------------------------------
# WEBSITE ANALYSIS
# -------------------------------------------------------------
ANALYSIS_TIMEOUT_MS=10000
ANALYSIS_USER_AGENT="Mozilla/5.0 BizOptics-Bot/1.0"

# -------------------------------------------------------------
# LOGGING
# Options: error | warn | log | debug | verbose
# -------------------------------------------------------------
LOG_LEVEL="debug"

# -------------------------------------------------------------
# REDIS (Optional — for caching & background queues)
# Not required in current version; reserved for future use
# -------------------------------------------------------------
# REDIS_URL="redis://localhost:6379"
